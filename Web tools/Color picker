javascript:(function(){if(!window.EyeDropper){alert('Your browser does not support the EyeDropper API. Try Chrome or Edge.');return}new EyeDropper().open().then(function(r){var hex=r.sRGBHex;var n=parseInt(hex.slice(1),16),rr=n>>16,gg=n>>8&255,bb=n&255;var d=document.createElement('div');d.style.cssText='position:fixed;top:20px;right:20px;z-index:2147483647;background:#fff;color:#000;padding:14px;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.4);font:13px monospace;text-align:center';d.innerHTML='<div style="width:100%;height:44px;border-radius:6px;border:1px solid #ccc;background:'+hex+'"></div><div style="margin-top:8px">'+hex+'<br>rgb('+rr+', '+gg+', '+bb+')</div>';var cp=document.createElement('button');cp.textContent='copy hex';cp.style.margin='8px 4px 0';cp.onclick=function(){navigator.clipboard.writeText(hex);cp.textContent='copied!'};var cl=document.createElement('button');cl.textContent='close';cl.style.margin='8px 4px 0';cl.onclick=function(){d.remove()};d.appendChild(cp);d.appendChild(cl);document.body.appendChild(d)}).catch(function(){})})()
