javascript:(function(){if(window.__nsb){window.__nsb.remove();window.__nsb=null;return}var D=document,box=D.createElement('div');window.__nsb=box;box.style.cssText='position:fixed;top:0;right:0;width:230px;height:100vh;z-index:2147483647;background:#0d1117;color:#e6edf3;font:13px/1.4 system-ui,sans-serif;box-shadow:-4px 0 20px rgba(0,0,0,.5);padding:14px;box-sizing:border-box;overflow:auto';function row(l,id,u){return '<div style="margin:10px 0;padding:8px;background:#161b22;border-radius:6px"><div style="font-size:11px;color:#8b949e;text-transform:uppercase;letter-spacing:.5px">'+l+'</div><div style="font-size:20px;font-weight:600"><span id="'+id+'">–</span> <span style="font-size:12px;color:#8b949e">'+u+'</span></div></div>'}box.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center"><b style="font-size:15px">📶 NetStatBuddy</b><span id="nsbX" style="cursor:pointer;color:#8b949e">✕</span></div>'+row('Ping','nsbPing','ms')+row('Jitter','nsbJit','ms')+row('Download','nsbDl','Mbps')+row('Upload','nsbUp','Mbps')+row('Connection','nsbConn','')+'<div id="nsbStat" style="font-size:11px;color:#8b949e;margin:8px 0">idle</div><button id="nsbRun" style="width:100%;padding:8px;background:#238636;color:#fff;border:0;border-radius:6px;cursor:pointer;font-size:13px">Run test</button>';D.body.appendChild(box);var $=function(id){return D.getElementById(id)};$('nsbX').onclick=function(){box.remove();window.__nsb=null};function set(id,v){$(id).textContent=v}function stat(s){$('nsbStat').textContent=s}var CD='https://speed.cloudflare.com/__down?bytes=',CU='https://speed.cloudflare.com/__up';function ping(n){var t=[];return(function nx(i){if(i>=n){var a=t.reduce(function(x,y){return x+y},0)/t.length,j=Math.sqrt(t.reduce(function(x,y){return x+(y-a)*(y-a)},0)/t.length);return{avg:a,jitter:j}}var s=performance.now();return fetch(CD+'0',{cache:'no-store'}).then(function(){t.push(performance.now()-s);return nx(i+1)})})(0)}function dl(b){var s=performance.now();return fetch(CD+b,{cache:'no-store'}).then(function(r){return r.arrayBuffer()}).then(function(buf){return buf.byteLength*8/((performance.now()-s)/1000)/1e6})}function ul(b){var d=new Uint8Array(b),s=performance.now();return fetch(CU,{method:'POST',body:d,cache:'no-store'}).then(function(){return b*8/((performance.now()-s)/1000)/1e6})}function conn(){var c=navigator.connection||{},p=[];if(c.effectiveType)p.push(c.effectiveType);if(c.rtt!=null)p.push('rtt '+c.rtt+'ms');if(c.downlink!=null)p.push('~'+c.downlink+'Mb');set('nsbConn',(navigator.onLine?'':'OFFLINE ')+(p.join(' · ')||'n/a'));$('nsbConn').style.fontSize='13px'}var busy=false;function run(){if(busy)return;busy=true;$('nsbRun').disabled=true;conn();stat('pinging…');ping(5).then(function(p){set('nsbPing',p.avg.toFixed(0));set('nsbJit',p.jitter.toFixed(0));stat('download…');return dl(1e7)}).then(function(d){set('nsbDl',d.toFixed(1));stat('upload…');return ul(5e6)}).then(function(u){set('nsbUp',u.toFixed(1));stat('done ✓')}).catch(function(e){stat('blocked here — try a plain page/new tab')}).then(function(){busy=false;$('nsbRun').disabled=false})}$('nsbRun').onclick=run;run()})()
